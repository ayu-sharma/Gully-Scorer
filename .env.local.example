# ────────────────────────────────────────────────────────────────
# Airtable configuration (OPTIONAL)
# ────────────────────────────────────────────────────────────────
# The app is fully functional WITHOUT Airtable — every match is saved to
# LocalStorage automatically. Add these credentials to additionally sync
# teams, players, matches and ball-by-ball data to Airtable.
#
# 1. Create a Personal Access Token: https://airtable.com/create/tokens
#    Scopes required: data.records:read, data.records:write, schema.bases:read
# 2. Find your Base ID: https://airtable.com/api  (looks like "appXXXXXXXXXXXXXX")
# 3. Copy this file to ".env.local" and fill in the values below.
#
# NOTE: Because there is no backend, these values are exposed to the browser
# (NEXT_PUBLIC_*). Use a token scoped to ONLY this base. See README "Security".
#
# Expected tables in the base (create them with these names):
#   Teams      — fields: Name (text), MatchId (text)
#   Players    — fields: Name (text), Team (text), MatchId (text)
#   Matches    — fields: MatchId (text), TeamA (text), TeamB (text),
#                Overs (number), Status (text), Result (long text),
#                Summary (long text), Payload (long text)
#   BallByBall — fields: MatchId (text), Innings (number), Over (text),
#                Label (text), Runs (number), Extra (text), Wicket (checkbox),
#                Striker (text), Bowler (text), Payload (long text)

# ────────────────────────────────────────────────────────────────
# Vercel KV (required for the /view live-score page on Vercel)
# ────────────────────────────────────────────────────────────────
# 1. In your Vercel project dashboard → Storage → Create → KV
# 2. Click "Connect" on the KV store — Vercel auto-adds these vars.
#    Or copy them from the store's ".env.local" tab.
#
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ────────────────────────────────────────────────────────────────
# Airtable configuration (OPTIONAL)
# ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_AIRTABLE_API_KEY=
NEXT_PUBLIC_AIRTABLE_BASE_ID=

# Optional: override default table names if yours differ.
NEXT_PUBLIC_AIRTABLE_TEAMS_TABLE=Teams
NEXT_PUBLIC_AIRTABLE_PLAYERS_TABLE=Players
NEXT_PUBLIC_AIRTABLE_MATCHES_TABLE=Matches
NEXT_PUBLIC_AIRTABLE_BALLS_TABLE=BallByBall
